# JIRA
JIRA_URL=https://redhat.atlassian.net
JIRA_USERNAME=your-email@redhat.com
JIRA_API_TOKEN=your-jira-api-token

# GitHub
GITHUB_TOKEN=<your-github-token>
GITHUB_FORK_OWNER=your-github-username
KRKN_REPO_URL=https://github.com/<username>/krkn
KRKN_REPO_PATH=/path/to/local/krkn

# Neo4j (required — run: docker compose up -d neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# LLM Backend (for FILTER phase — optional, falls back to keyword filter)
# Provider: claude_code | ollama | anthropic | openai | google | none
# claude_code uses the Claude Code CLI (no API key needed, uses your subscription)
# LLM_PROVIDER=claude_code
# LLM_MODEL=claude-sonnet-4-6

# Per-phase model routing (optional — falls back to LLM_PROVIDER/LLM_MODEL if not set)
# LLM_FILTER_PROVIDER=anthropic
# LLM_FILTER_MODEL=claude-sonnet-4-6
# LLM_MAP_PROVIDER=anthropic
# LLM_MAP_MODEL=claude-sonnet-4-6
# LLM_ANALYZE_PROVIDER=anthropic
# LLM_ANALYZE_MODEL=claude-opus-4-6

# Ollama (default local LLM — auto-detected if running)
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (Claude API — for standalone CLI/dashboard without Claude Code)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google Gemini
# GOOGLE_API_KEY=...

# krkn repo (local clone — required for scenario indexing)
KRKN_REPO_PATH=~/krkn

# Target release
OCP_RELEASE=4.21
